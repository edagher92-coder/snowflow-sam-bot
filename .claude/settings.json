{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Skill",
      "mcp__Claude_Code_Remote__create_trigger",
      "mcp__Claude_Code_Remote__send_later"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-opus-5",
  "effortLevel": "high",
  "autoCompactEnabled": true,
  "autoCompactWindow": 150000,
  "fallbackModel": [
    "haiku"
  ],
  "enableAllProjectMcpServers": false,
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "playground@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": false,
    "pyright-lsp@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "ai-specialists@hq-marketplace": true,
    "community-ai-agent-tooling@hq-marketplace": false,
    "community-business-ops@hq-marketplace": false,
    "community-customer-support@hq-marketplace": false,
    "community-data-analytics@hq-marketplace": false,
    "community-design-creative@hq-marketplace": false,
    "community-dev-engineering@hq-marketplace": false,
    "community-devops-infra@hq-marketplace": false,
    "community-education-training@hq-marketplace": false,
    "community-email-newsletters@hq-marketplace": false,
    "community-finance-invoicing@hq-marketplace": false,
    "community-hr-recruiting@hq-marketplace": false,
    "community-legal-regulated@hq-marketplace": false,
    "community-marketing-content@hq-marketplace": false,
    "community-other@hq-marketplace": false,
    "community-sales-crm@hq-marketplace": false,
    "community-security-research@hq-marketplace": false,
    "community-seo-web@hq-marketplace": false,
    "community-social-media@hq-marketplace": false,
    "community-video-audio-media@hq-marketplace": false,
    "community-writing-editing@hq-marketplace": false,
    "watch@hq-marketplace": false,
    "notebooklm@hq-marketplace": false,
    "graphify-knowledge-graph@hq-marketplace": false,
    "obsidian@hq-marketplace": false,
    "impeccable@hq-marketplace": true,
    "ponytail@hq-marketplace": false,
    "snowflow-hq@hq-marketplace": true,
    "hq-playbooks@hq-marketplace": true
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/tools/claude_status_line.py",
    "refreshInterval": 10
  },
  "extraKnownMarketplaces": {
    "hq-marketplace": {
      "source": {
        "source": "github",
        "repo": "edagher92-coder/Claude-code-Agents"
      },
      "autoUpdate": true
    }
  }
}
